---
title: Code App Data Flow
---
flowchart TD
    User["Requester"]

    subgraph Runtime["Runtime experience"]
        ReactApp["Power Apps code app shell<br/>Vite + React + TypeScript"]
        AppTsx["src/App.tsx<br/>conversation UI, form UI, actions"]
        Engine["src/intakeEngine.ts<br/>local fallback analysis"]
        AgentAdapter["src/agentFlow.ts<br/>flow adapter and JSON parser"]
        GeneratedClient["Generated flow client<br/>IntakeCopilot_CanvasRunService.Run"]
        Draft["Merged intake draft<br/>required fields, size, effort, developer notes"]
        Readiness["Readiness score<br/>ready, needs review, needs intake"]
        Mapper["toPowerPlatformPayload<br/>crb_* Dataverse field shape"]
    end

    subgraph LiveAgent["Hosted agent path"]
        Wrapper["Power Automate wrapper flow<br/>IntakeCopilot_CanvasRun"]
        Copilot["Microsoft 365 Copilot action<br/>Response"]
        AgentJson["Agent JSON response<br/>draft fields and next question"]
    end

    subgraph LocalActions["Current save and handoff actions"]
        DraftLocal["Save Draft<br/>localStorage draft payload"]
        SubmitLocal["Submit Request<br/>localStorage submitted payload"]
        CopyPayload["Copy JSON payload<br/>for inspection or handoff"]
        BrowserStorage["Browser localStorage"]
        Clipboard["Clipboard"]
    end

    subgraph Publish["Power Apps code app publish path"]
        Build["npm build<br/>static app bundle"]
        Config["power.config.json<br/>flow connection reference"]
        Push["Power Apps push<br/>solution-aware deployment"]
        Hosted["Published code app<br/>Power Platform environment"]
    end

    subgraph Future["Future live record write"]
        FlowOrApi["Power Automate flow<br/>or Dataverse API"]
        Requests["Dataverse table<br/>crb_intakerequest / Request Intakes"]
    end

    User --> ReactApp
    ReactApp --> AppTsx
    AppTsx --> AgentAdapter
    AgentAdapter --> GeneratedClient
    GeneratedClient --> Wrapper
    Wrapper --> Copilot
    Copilot --> AgentJson
    AgentJson --> Draft
    AgentAdapter -. local fallback .-> Engine
    Engine -. fallback draft .-> Draft
    Draft --> Readiness
    Draft --> Mapper
    Mapper --> DraftLocal
    Mapper --> SubmitLocal
    Mapper --> CopyPayload
    DraftLocal --> BrowserStorage
    SubmitLocal --> BrowserStorage
    CopyPayload --> Clipboard
    ReactApp --> Build
    Build --> Config
    Config --> Push
    Push --> Hosted
    Mapper -. future .-> FlowOrApi
    FlowOrApi -. future .-> Requests

