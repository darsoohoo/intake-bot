<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="WorkManagement" constructor="RequestIntakeAgentChatV8" version="0.0.1" display-name-key="Request Intake Agent Chat V8" description-key="Embedded intake assistant for model-driven Request Intake forms." control-type="standard" >
    <!--external-service-usage node declares whether this 3rd party PCF control is using external service or not, if yes, this control will be considered as premium and please also add the external domain it is using.
    If it is not using any external service, please set the enabled="false" and DO NOT add any domain below. The "enabled" will be false by default.
    Example1:
      <external-service-usage enabled="true">
        <domain>www.Microsoft.com</domain>
      </external-service-usage>
    Example2:
      <external-service-usage enabled="false">
      </external-service-usage>
    -->
    <external-service-usage enabled="false">
      <!--UNCOMMENT TO ADD EXTERNAL DOMAINS
      <domain></domain>
      <domain></domain>
      -->
    </external-service-usage>
    <!-- property node identifies a specific, configurable piece of data that the control expects from CDS -->
    <property name="conversationJson" display-name-key="Conversation JSON" description-key="Stores or displays the intake assistant transcript." of-type="Multiple" usage="bound" required="false" />
    <property name="requestTitle" display-name-key="Request Title" description-key="Suggested request title." of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="description" display-name-key="Description" description-key="Suggested problem or request description." of-type="Multiple" usage="bound" required="false" />
    <property name="businessImpact" display-name-key="Business Impact" description-key="Suggested business impact." of-type="Multiple" usage="bound" required="false" />
    <property name="affectedArea" display-name-key="Affected Area" description-key="Suggested affected Power Platform area." of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="desiredOutcome" display-name-key="Desired Outcome" description-key="Suggested desired outcome." of-type="Multiple" usage="bound" required="false" />
    <property name="estimatedEffort" display-name-key="Estimated Effort" description-key="Suggested estimated effort." of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="estimatedDuration" display-name-key="Estimated Duration" description-key="Suggested estimated duration." of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="missingRequirements" display-name-key="Missing Requirements" description-key="Suggested missing requirements." of-type="Multiple" usage="bound" required="false" />
    <property name="additionalInformation" display-name-key="Additional Information" description-key="Suggested developer notes." of-type="Multiple" usage="bound" required="false" />
    <!--
      Property node's of-type attribute can be of-type-group attribute.
      Example:
      <type-group name="numbers">
        <type>Whole.None</type>
        <type>Currency</type>
        <type>FP</type>
        <type>Decimal</type>
      </type-group>
      <property name="sampleProperty" display-name-key="Property_Display_Key" description-key="Property_Desc_Key" of-type-group="numbers" usage="bound" required="true" />
    -->
    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/RequestIntakeAgentControl.css" order="1" />
      <!-- UNCOMMENT TO ADD MORE RESOURCES
      <css path="css/RequestIntakeAgentControl.css" order="1" />
      <resx path="strings/RequestIntakeAgentControl.1033.resx" version="1.0.0" />
      -->
    </resources>
    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
