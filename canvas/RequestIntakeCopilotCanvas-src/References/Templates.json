ic\" defaultValue=\"false\" />\r\n    <appMagic:includeProperty name=\"Underline\" defaultValue=\"false\" />\r\n    <appMagic:includeProperty name=\"Strikethrough\" defaultValue=\"false\" />\r\n    <appMagic:includeProperty name=\"Color\" defaultValue=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"FontWeight\" nullDefault=\"\" />\r\n    <appMagic:includeProperty name=\"Align\" />\r\n    <!-- Design - Padding -->\r\n    <appMagic:includeProperty name=\"PaddingTop\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingRight\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingBottom\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingLeft\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <!-- Position and Size -->\r\n    <appMagic:includeProperty name=\"X\" />\r\n    <appMagic:includeProperty name=\"Y\" />\r\n    <appMagic:includeProperty name=\"Width\" defaultValue=\"320\" phoneDefaultValue=\"560\" webDefaultValue=\"320\" />\r\n    <appMagic:includeProperty name=\"Height\" defaultValue=\"32\" phoneDefaultValue=\"64\" webDefaultValue=\"32\" />\r\n    <appMagic:includeProperty name=\"Visible\" />\r\n    <appMagic:includeProperty name=\"DisplayMode\" />\r\n    <!-- Trigger Output and Validation State -->\r\n    <appMagic:includeProperty name=\"TriggerOutput\" />\r\n    <appMagic:includeProperty name=\"ValidationState\" />\r\n    <!-- Behavior -->\r\n    <appMagic:includeProperty name=\"OnChange\" direction=\"in\" isPrimaryBehaviorProperty=\"true\" />\r\n    <!-- Hidden properties -->\r\n    <appMagic:includeProperty name=\"maximumHeight\" defaultValue=\"768\" />\r\n    <appMagic:includeProperty name=\"maximumWidth\" defaultValue=\"1366\" />\r\n    <appMagic:includeProperty name=\"minimumHeight\" defaultValue=\"30\" />\r\n  