      "Template": "<widget xmlns=\"http://openajax.org/metadata\" xmlns:appMagic=\"http://schemas.microsoft.com/appMagic\" spec=\"1.0\" id=\"http://microsoft.com/appmagic/modernButton\" name=\"modernButton\" jsClass=\"AppMagic.Controls.ModernButtonControl\" version=\"1.0.0\" styleable=\"true\" runtimeCost=\"1\" enabledForFeatureGate=\"Controls.ModernButtonControl\">\r\n  <author name=\"Microsoft AppMagic\" />\r\n  <license type=\"text/html\"><![CDATA[<p>Copyright (C) Microsoft Corporation. All rights reserved.</p>]]></license>\r\n  <description><![CDATA[Modern button control using Fluent UI v9. Supports 5 appearance styles (Primary, Secondary, Outline, Subtle, Transparent), icon with layout options, and BasePaletteColor theming.]]></description>\r\n  <requires>\r\n    <require type=\"javascript\" src=\"/openSource/modified/pcfplatformlibs/fluent_9_4_0.js\" />\r\n    <require type=\"javascript\" src=\"/ctrllib/shared/js/PowerAppsControlsFluentIcons.js\" />\r\n    <require type=\"javascript\" src=\"js/modernButton.js\" />\r\n  </requires>\r\n  <appMagic:capabilities contextualViewsEnabled=\"true\" autoDisabledViewState=\"true\" isVersionFlexible=\"true\" />\r\n  <appMagic:accessibilityChecks controlIsInteractive=\"true\" />\r\n  <content><![CDATA[]]></content>\r\n  <properties>\r\n    <!-- Button-specific custom properties -->\r\n    <property name=\"Appearance\" localizedName=\"##button_Appearance##\" datatype=\"ButtonAppearance\" defaultValue=\"%ButtonAppearance.RESERVED%.Primary\" isExpr=\"true\" direction=\"in\">\r\n      <title>Appearance</title>\r\n      <appMagic:category>design</appMagic:category>\r\n      <appMagic:displayName>##button_Appearance_DisplayName##</appMagic:displayName>\r\n      <appMagic:tooltip>##button_Appearance_Tooltip##</appMagic:tooltip>\r\n    </property>\r\n    <property name=\"Icon\" localizedName=\"##button_Icon##\" datatype=\"String\" defaultValue=\"&quot;&quot;\" isExpr=\"true\" direction=\"in\">\r\n      <title>Icon</title>\r\n      <appMagic:category>design</appMagic:category>\r\n      <appMagic:displayName>##button_Icon_DisplayName##</appMagic:displayName>\r\n      <appMagic:tooltip>##button_Icon_Tooltip##</appMagic:tooltip>\r\n    </property>\r\n    <property name=\"Layout\" localizedName=\"##button_Layout##\" datatype=\"ButtonLayout\" defaultValue=\"%ButtonLayout.RESERVED%.IconBefore\" isExpr=\"true\" direction=\"in\">\r\n      <title>Layout</title>\r\n      <appMagic:category>design</appMagic:category>\r\n      <appMagic:displayName>##button_Layout_DisplayName##</appMagic:displayName>\r\n      <appMagic:tooltip>##button_Layout_Tooltip##</appMagic:tooltip>\r\n    </property>\r\n    <property name=\"IconStyle\" localizedName=\"##button_IconStyle##\" datatype=\"IconStyle\" defaultValue=\"%IconStyle.RESERVED%.Outline\" isExpr=\"true\" direction=\"in\">\r\n      <title>Icon style</title>\r\n      <appMagic:category>design</appMagic:category>\r\n      <appMagic:displayName>##button_IconStyle_DisplayName##</appMagic:displayName>\r\n      <appMagic:tooltip>##button_IconStyle_Tooltip##</appMagic:tooltip>\r\n    </property>\r\n    <property name=\"IconRotation\" localizedName=\"##button_IconRotation##\" datatype=\"Number\" defaultValue=\"0\" isExpr=\"true\" direction=\"in\">\r\n      <title>Icon rotation</title>\r\n      <appMagic:category>design</appMagic:category>\r\n      <appMagic:displayName>##button_IconRotation_DisplayName##</appMagic:displayName>\r\n      <appMagic:tooltip>##button_IconRotation_Tooltip##</appMagic:tooltip>\r\n    </property>\r\n  </properties>\r\n  <appMagic:includeProperties>\r\n    <!-- Data -->\r\n    <appMagic:includeProperty name=\"Text\" defaultValue=\"##Button_DefaultValue_Text##\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"ContentLanguage\" />\r\n    <appMagic:includeProperty name=\"DisplayMode\" />\r\n    <appMagic:includeProperty name=\"OnSelect\" direction=\"in\" isPrimaryBehaviorProperty=\"true\" isPrimaryInputProperty=\"true\" />\r\n    <appMagic:includeProperty name=\"BasePaletteColor\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <!-- Font -->\r\n    <appMagic:includeProperty name=\"Font\" defaultValue=\"\" nullDefault=\"\" isExpr=\"false\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"Size\" defaultValue=\"\" phoneDefaultValue=\"24\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"Color\" defaultValue=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"FontWeight\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"Italic\" />\r\n    <appMagic:includeProperty name=\"Underline\" />\r\n    <appMagic:includeProperty name=\"Strikethrough\" />\r\n    <appMagic:includeProperty name=\"Align\" defaultValue=\"\" />\r\n    <appMagic:includeProperty name=\"VerticalAlign\" defaultValue=\"\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <!-- Design - Border -->\r\n    <appMagic:includeProperty name=\"BorderStyle\" defaultValue=\"\" isExpr=\"false\" />\r\n    <appMagic:includeProperty name=\"BorderThickness\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"BorderColor\" defaultValue=\"\" isExpr=\"true\" />\r\n    <!-- Design - Radius -->\r\n    <appMagic:includeProperty name=\"RadiusTopLeft\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"RadiusTopRight\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"RadiusBottomLeft\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <appMagic:includeProperty name=\"RadiusBottomRight\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" isResettableToManifestDefault=\"true\" isLinkableToParentTheme=\"true\" />\r\n    <!-- Design - Padding -->\r\n    <appMagic:includeProperty name=\"PaddingTop\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingRight\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingBottom\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <appMagic:includeProperty name=\"PaddingLeft\" defaultValue=\"\" nullDefault=\"\" isExpr=\"true\" />\r\n    <!-- Position and Size -->\r\n    <appMagic:includeProperty name=\"X\" />\r\n    <appMagic:includeProperty name=\"Y\" />\r\n    <appMagic:includeProperty name=\"Width\" defaultValue=\"96\" phoneDefaultValue=\"280\" />\r\n    <appMagic:includeProperty name=\"Height\" defaultValue=\"32\" phoneDefaultValue=\"64\" />\r\n    <appMagic:includeProperty name=\"Visible\" />\r\n    <!-- Accessibility -->\r\n    <appMagic:includeProperty name=\"AccessibleLabel\" />\r\n    <!-- Tooltip -->\r\n    <appMagic:includeProperty name=\"Tooltip\" />\r\n    <!-- Hidden properties -->\r\n    <appMagic:includeProperty name=\"maximumHeight\" defaultValue=\"768\" />\r\n    <appMagic:includeProperty name=\"maximumWidth\" defaultValue=\"1366\" />\r\n    <appMagic:includeProperty name=\"minimumHeight\" defaultValue=\"10\" />\r\n    <appMagic:includeProperty name=\"minimumWidth\" defaultValue=\"10\" />\r\n  </appMagic:includeProperties>\r\n  <!-- Property Dependencies -->\r\n  <appMagic:propertyDependencies />\r\n  <appMagic:insertMetadata>\r\n    <appMagic:category name=\"Input\" priority=\"10\" />\r\n  </appMagic:insertMetadata>\r\n  <!-- Display metadata -->\r\n  <appMagic:displayMetadata>\r\n    <!-- General section -->\r\n    <appMagic:section type=\"GeneralSection\">\r\n      <appMagic:property name=\"Text\" />\r\n      <appMagic:property name=\"Icon\" displayType=\"FluentIcon\" />\r\n      <appMagic:property name=\"Layout\" itemsOrder=\"IconBefore;IconAfter;TextOnly;IconOnly\" />\r\n      <appMagic:property name=\"AccessibleLabel\" />\r\n    </appMagic:section>\r\n    <!-- Behavior section -->\r\n    <appMagic:section type=\"BehaviorSection\">\r\n      <appMagic:property name=\"DisplayMode\" />\r\n      <appMagic:property name=\"Visible\" />\r\n    </appMagic:section>\r\n    <!-- Size and Position section -->\r\n    <appMagic:section type=\"SizeAndPositioningSection\">\r\n      <appMagic:property name=\"Align\" itemsOrder=\"Left;Center;Right;Justify\" labelOverride=\"##FontAlign_Property##\" showInFloatie=\"true\" showInCommandBar=\"true\" floatieDisplayType=\"FaceplateIconEnum\" />\r\n      <appMagic:property name=\"VerticalAlign\" />\r\n      <appMagic:property name=\"IconRotation\" />\r\n      <appMagic:propertyGroup name=\"Position\">\r\n        <appMagic:property name=\"X\" />\r\n        <appMagic:property name=\"Y\" />\r\n      </appMagic:propertyGroup>\r\n      <appMagic:propertyGroup name=\"Size\">\r\n        <appMagic:property name=\"Width\" />\r\n        <appMagic:property name=\"Height\" />\r\n      </appMagic:propertyGroup>\r\n      <appMagic:propertyGroup name=\"Padding\">\r\n        <appMagic:property name=\"PaddingTop\" labelOverride=\"##Padding_Top_Title##\" />\r\n        <appMagic:property name=\"PaddingRight\" labelOverride=\"##Padding_Right_Title##\" />\r\n        <appMagic:property name=\"PaddingBottom\" labelOverride=\"##Padding_Bottom_Title##\" />\r\n        <appMagic:property name=\"PaddingLeft\" labelOverride=\"##Padding_Left_Title##\" />\r\n      </appMagic:propertyGroup>\r\n    </appMagic:section>\r\n    <!-- Style and Theme section -->\r\n    <appMagic:section type=\"StyleAndThemeSection\">\r\n      <appMagic:property name=\"Appearance\" />\r\n      <appMagic:property name=\"IconStyle\" />\r\n      <appMagic:property name=\"BasePaletteColor\" displayType=\"ColorPalette\" />\r\n      <appMagic:property name=\"Font\" displayType=\"FontEnum\" showInFloatie=\"true\" showInCommandBar=\"true\" />\r\n      <appMagic:property name=\"Size\" labelOverride=\"##FontSize_Property##\" showInFloatie=\"true\" showInCommandBar=\"true\" />\r\n      <appMagic:property name=\"Color\" showInFloatie=\"true\" showInCommandBar=\"true\" />\r\n      <appMagic:property name=\"FontWeight\" displayType=\"EnumIcon\" itemsOrder=\"Bold;Semibold;Normal;Lighter\" />\r\n      <appMagic:propertyGroup name=\"Style\">\r\n        <appMagic:property name=\"Italic\" displayType=\"ToggleButton\" />\r\n        <appMagic:property name=\"Underline\" displayType=\"ToggleButton\" />\r\n        <appMagic:property name=\"Strikethrough\" displayType=\"ToggleButton\" />\r\n      </appMagic:propertyGroup>\r\n      <appMagic:propertyGroup name=\"Border\">\r\n        <appMagic:property name=\"BorderStyle\" />\r\n        <appMagic:property name=\"BorderThickness\" />\r\n        <appMagic:property name=\"BorderColor\" />\r\n      </appMagic:propertyGroup>\r\n      <appMagic:propertyGroup name=\"Radius\">\r\n        <appMagic:property name=\"RadiusTopLeft\" labelOverride=\"##Radius_TopLeft_Title##\" />\r\n        <appMagic:property name=\"RadiusTopRight\" labelOverride=\"##Radius_TopRight_Title##\" />\r\n        <appMagic:property name=\"RadiusBottomLeft\" labelOverride=\"##Radius_BottomLeft_Title##\" />\r\n        <appMagic:property name=\"RadiusBottomRight\" labelOverride=\"##Radius_BottomRight_Title##\" />\r\n      </appMagic:propertyGroup>\r\n    </appMagic:section>\r\n  </appMagic:displayMetadata>\r\n</widget>",
      "Version": "1.0.0"
    }
